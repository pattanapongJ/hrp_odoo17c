<odoo>
    <record id="fsm_template_form_view_inherit" model="ir.ui.view">
        <field name="name">fsm.template.form.inherit</field>
        <field name="model">fsm.template</field>
        <field name="inherit_id" ref="fieldservice.fsm_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//group/group[1]" position="inside">
                <field name="show_use_current_location" invisible="1" />
                <field
                    name="use_current_location"
                    invisible="not show_use_current_location"
                />
            </xpath>
        </field>
    </record>
</odoo>
