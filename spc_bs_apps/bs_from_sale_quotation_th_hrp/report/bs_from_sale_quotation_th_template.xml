<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- custom report template -->
    <template id="request_layout">
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <!-- Multicompany -->
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>
                        
        <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
            <div class="row pt-2 pb-2" style="font-family: 'Kanit-Light';">
                <t t-call="bs_from_sale_quotation_th_hrp.report_compay_info"/>
                <div t-if="o.brand_logo_id.logo" class="col-2 p-0 m-0" style="
                        display: -webkit-box;
                        -webkit-box-pack: center;
                        -webkit-box-orient: vertical;
                        -webkit-box-align: center;
                        display: flex;
                        flex-direction: column;">
                    <img t-att-src="image_data_uri(o.brand_logo_id.logo)" style="
                            max-width: 95%;     /* Limit the maximum width */
                            max-height: 86px;  /* Limit the maximum height */
                            width: auto;        /* Scale width while maintaining aspect ratio */
                            height: auto;       /* Scale height while maintaining aspect ratio */
                            object-fit: contain; /* Ensures the image fits inside the boundary */
                        " alt="Brand Logo"/>
                </div>
                <div class="col-3 text-right pd-3">
                    <span style="font-size: 25px" >ใบเสนอราคา</span>
                    <br/>
                    <div t-if="report_type == 'pdf'" class="text-muted text-right col" style="font-size:12.5px">
                        <li class="list-inline-item">
                                <div class="row">
                                    <span class="page" />/
                                    <span class="topage" />
                                </div>
                        </li>
                    </div>
                </div>
            </div>
            <t t-call="bs_from_sale_quotation_th_hrp.report_partner_info"/>
        </div>

        <!-- content  or article-->
        <div t-attf-class="article o_report_layout_standard o_company_#{company.id}_layout"
            t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id"
            t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-raw="0" />
        </div>

        <!-- footer -->
        <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout">
            <div class="last-page">
                <t t-call="bs_from_sale_quotation_th_hrp.report_footer"/>
            </div>
        </div>
    </template>
</odoo>