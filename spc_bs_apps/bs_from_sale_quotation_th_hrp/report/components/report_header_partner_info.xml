<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_partner_info">
        <div class="row border-top border-dark border-bottom border-dark pt-2 pb-2" style="font-family: 'Kanit-Light'; font-size: 13.64px">
            <div class="col-7 pt-1 pd-1">
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left font-weight-bold">
                        <span>รหัสคู่ค้า : </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.partner_invoice_id.ref">
                                <span t-esc="o.partner_invoice_id.ref" />
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.partner_invoice_id.ref">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left font-weight-bold">
                        <span>ชื่อคู่ค้า : </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.partner_invoice_id.name">
                                <span t-field="o.partner_invoice_id.name" />
                            </t>
                            <t t-if="o.partner_invoice_id.branch">
                                <span>(</span>
                                <span t-field="o.partner_invoice_id.branch" />
                                <span>)</span>
                            </t>
                            <t t-if="not o.partner_invoice_id.name and not o.partner_invoice_id.branch">
                                    - 
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left font-weight-bold">
                        <span>เลขประจำตัวผู้เสียภาษี : </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.partner_invoice_id.vat">
                                <span t-esc="o.partner_invoice_id.vat" />
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.partner_invoice_id.vat">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left font-weight-bold">
                        <span>ที่อยู่ : </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <t t-if="o.partner_invoice_id.street">
                            <span t-field="o.partner_invoice_id.street" style="margin-right: 5px;" />
                        </t>
                        <t t-if="o.partner_invoice_id.street2">
                            <span t-field="o.partner_invoice_id.street2" style="margin-right: 5px;" />
                        </t>
                        <t t-if="o.partner_invoice_id.city">
                            <span t-esc="o.partner_invoice_id.city" style="margin-right: 5px;" />
                        </t>
                        <br/>
                        <t t-if="o.partner_invoice_id.state_id">
                            <span t-esc="o.partner_invoice_id.state_id.name" style="margin-right: 5px;" />
                        </t>
                        <t t-if="o.partner_invoice_id.zip">
                            <span t-esc="o.partner_invoice_id.zip" style="margin-right: 5px;" />
                        </t>
                        <t t-if="o.partner_invoice_id.country_id">
                            <span t-field="o.partner_invoice_id.country_id.name" />
                        </t>
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 mb-0 p-0 text-left font-weight-bold">
                        <span>สถานที่จัดส่ง : </span>
                    </div>
                    <div class="col-8 p-0 mb-0 text-left">
                        <span>
                            <t t-if="o.partner_shipping_id.name">
                                <span t-field="o.partner_shipping_id.name" />
                            </t>
                            <t t-if="o.partner_shipping_id.branch">
                                <span>(</span>
                                <span t-field="o.partner_shipping_id.branch" />
                                <span>)</span>
                            </t>
                            <t t-if="not o.partner_shipping_id.name and not o.partner_shipping_id.branch">
                                    - 
                            </t>
                        </span>
                    </div>
                </div>
            </div>

            <div class="col-5 pt-1 pb-1 mr-1 ml-5">
                <div class="row" style="background-color: #d0d0d0;">
                    <div class="col-6 p-0 mb-0 pl-2 text-left">
                        <b>เลขที่เอกสาร :  </b>
                    </div>
                    <div class="col-6 p-0 mb-0text-left" style="margin-left:-20px">
                        <span t-field="o.name" />
                    </div>
                </div>
                <div class="row" style="background-color: #d0d0d0;">
                    <div class="col-6 p-0 mb-0 pl-2 text-left">
                        <b>วันที่เอกสาร : </b>
                    </div>
                    <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                        <span t-field="o.date_order" t-options='{"widget": "date","format": "dd/MM/yyyy"}' />
                    </div>
                </div>
                <div class="row" style="background-color: #d0d0d0;">
                    <div class="col-6 p-0 mb-0 pl-2 text-left">
                        <b>มีผลถึงวันที่ : </b>
                    </div>
                    <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                        <span>
                            <t t-if="o.validity_date">
                                <span t-field="o.validity_date" t-options='{"widget": "date","format": "dd/MM/yyyy"}'/>
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.validity_date">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row" style="background-color: #d0d0d0;">
                    <div class="col-6 p-0 mb-0 pl-2 text-left">
                        <b>เงื่อนไขการชำระเงิน : </b>
                    </div>
                    <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                        <span>
                            <t t-if="o.payment_term_id">
                                <span t-field="o.payment_term_id.name"/>
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.payment_term_id">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
                <div class="row" style="background-color: #d0d0d0;">
                    <div class="col-6 p-0 mb-0 pl-2 text-left">
                        <b>พนักงานขาย : </b>
                    </div>
                    <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                        <span>
                            <t t-if="o.user_id">
                                <span t-field="o.user_id.name"/>
                            </t>
                        </span>
                        <span>
                            <t t-if="not o.user_id">
                                <span> - </span>
                            </t>
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>