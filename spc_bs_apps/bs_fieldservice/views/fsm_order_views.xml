                        </div>
                    </group>
                    <group
                        string="Supervisor's Comment"
                        invisible="technician_profile != 'phe'"
                    >
                        <field
                            name="sr_supervisor_comment"
                            nolabel="1"
                            colspan="2"
                            placeholder="Enter supervisor's comment..."
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
