<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="bs_fieldservice.ServiceReportTable">
        <div class="o_bs_line_table table-responsive">
            <table t-if="profile === 'phe'" class="table table-sm table-bordered mb-2">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Check Sheet</th>
                        <th>Tag No.</th>
                        <th>Maker / Model</th>
                        <th>H/HS/E</th>
                        <th>Job Type</th>
                        <th>Mech Clean</th>
                        <th>Re-gasket</th>
                        <th>PT Test</th>
                        <th>Hydro Test</th>
                        <th>Result</th>
                        <th t-if="!props.readonly"></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="list.records" t-as="record" t-key="record.id">
                        <tr>
                            <td t-esc="record_index + 1"/>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.check_sheet_no"
                                    t-on-change="(ev) => this.onTextChange(record, 'check_sheet_no', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.tag_no"
                                    t-on-change="(ev) => this.onTextChange(record, 'tag_no', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.maker_model"
                                    t-on-change="(ev) => this.onTextChange(record, 'maker_model', ev)"/>
                            </td>
                            <td>
                                <select class="form-select form-select-sm"
                                    t-on-change="(ev) => this.onSelectChange(record, 'report_type', ev)">
                                    <option value="h" t-att-selected="record.data.report_type === 'h'">H</option>
                                    <option value="hs" t-att-selected="record.data.report_type === 'hs'">HS</option>
                                    <option value="e" t-att-selected="record.data.report_type === 'e'">E</option>
                                </select>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.job_type"
                                    t-on-change="(ev) => this.onTextChange(record, 'job_type', ev)"/>
                            </td>
                            <td class="text-center">
                                <input type="checkbox"
                                    t-att-checked="record.data.mech_clean"
                                    t-on-change="(ev) => this.onCheckChange(record, 'mech_clean', ev)"/>
                            </td>
                            <td class="text-center">
                                <input type="checkbox"
                                    t-att-checked="record.data.re_gasket"
                                    t-on-change="(ev) => this.onCheckChange(record, 're_gasket', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.pt_test_status"
                                    t-on-change="(ev) => this.onTextChange(record, 'pt_test_status', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.hydro_test"
                                    t-on-change="(ev) => this.onTextChange(record, 'hydro_test', ev)"/>
                            </td>
                            <td>
                                <select class="form-select form-select-sm"
                                    t-on-change="(ev) => this.onSelectChange(record, 'result', ev)">
                                    <option value="pending" t-att-selected="record.data.result !== 'pass'">Pending</option>
                                    <option value="pass" t-att-selected="record.data.result === 'pass'">Pass</option>
                                </select>
                            </td>
                            <td t-if="!props.readonly" class="text-center">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                    t-on-click="() => this.removeLine(record)">
                                    <i class="fa fa-trash-o"/>
                                </button>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
            <table t-elif="profile === 'pump'" class="table table-sm table-bordered mb-2">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tag No.</th>
                        <th>Maker / Model</th>
                        <th>Work Done</th>
                        <th>Vibration Before</th>
                        <th>Vibration After</th>
                        <th>Alignment</th>
                        <th>Result</th>
                        <th t-if="!props.readonly"></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="list.records" t-as="record" t-key="record.id">
                        <tr>
                            <td t-esc="record_index + 1"/>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.tag_no"
                                    t-on-change="(ev) => this.onTextChange(record, 'tag_no', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.maker_model"
                                    t-on-change="(ev) => this.onTextChange(record, 'maker_model', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.work_done"
                                    t-on-change="(ev) => this.onTextChange(record, 'work_done', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.vibration_before"
                                    t-on-change="(ev) => this.onTextChange(record, 'vibration_before', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.vibration_after"
                                    t-on-change="(ev) => this.onTextChange(record, 'vibration_after', ev)"/>
                            </td>
                            <td>
                                <input type="text" class="form-control form-control-sm"
                                    t-att-value="record.data.alignment"
                                    t-on-change="(ev) => this.onTextChange(record, 'alignment', ev)"/>
                            </td>
                            <td>
                                <select class="form-select form-select-sm"
                                    t-on-change="(ev) => this.onSelectChange(record, 'result', ev)">
                                    <option value="pending" t-att-selected="record.data.result !== 'pass'">Pending</option>
                                    <option value="pass" t-att-selected="record.data.result === 'pass'">Pass</option>
                                </select>
                            </td>
                            <td t-if="!props.readonly" class="text-center">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                    t-on-click="() => this.removeLine(record)">
                                    <i class="fa fa-trash-o"/>
                                </button>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
            <button t-if="!props.readonly" type="button" class="btn btn-link p-0" t-on-click="addLine">
                <i class="fa fa-plus-square-o me-1"/>Add Row
            </button>
        </div>
    </t>
</templates>
