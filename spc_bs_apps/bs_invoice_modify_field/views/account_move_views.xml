<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.form.apply.down.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">

            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='price_unit']"
                position="before">
                <field name="apply_down_payment" optional="hide" />
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/form//field[@name='price_unit']"
                position="before">
                <field name="apply_down_payment" />
            </xpath>

        </field>
    </record>

</odoo>
