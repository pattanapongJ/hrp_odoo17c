<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_header_info">
        <div style="font-family: 'THSarabunNew'; font-size: 18px;">
            <div class="row">
                <div class="col-6"/>
                <div class="col-1"/>
                <div class="col-5" style="margin-left: 20px;">
                    <div class="row">
                        <div style="padding-left: 60px;">
                            <span style="text-align: left;" t-field="o.name"/>
                        </div>
                    </div>
                    <div class="row" style="margin-right: 50px; margin-top: 40px;">
                        <span style="text-align: left;" t-field="o.invoice_date" t-options="{&quot;widget&quot;:&quot;date&quot;}"/>
                    </div>
                    <div class="row" style="margin-top: 40px; padding-right:30px;">
                        <div class="col-2" style="white-space: nowrap; padding-left:5px;">
                            <span t-field="o.invoice_payment_term_id.name"/>
                        </div>
                        <div class="col-7">
                        </div>
                        <div class="col-3" style="padding-left:7.5px;">
                            <span t-field="o.invoice_date_due"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row" style="margin-top: 40px; padding-left: 30px;">
                <div class="col-1"/>
                <div class="col-4" style="margin-left: 15px; padding-top: 10px;">
                    <span style="text-align: left;" t-field="o.payment_reference"/>
                </div>
                <div class="col-3"/>
                <div class="col-4" style="margin-left: 5px; padding-top: 10px;">
                    <span t-field="o.invoice_user_id"/>
                </div>
            </div>
        </div>
    </template>
</odoo>