<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_header_info">
        <div style="font-family: 'THSarabunNew'; font-size: 14px;">
            <div class="row" style="margin-top: 20px; margin-left: 20px;">
                <div class="col-6"></div>
                <div class="col-2"></div>
                <div class="col-4">
                    <div class="row">
                        <div>
                            <span style="text-align: left;" t-field="o.name" />
                        </div>
                    </div>
                    <div class="row" style="margin-top: 25px;">
                        <span style="text-align: left;" t-field="o.invoice_date" 
                            t-options='{"widget":"date"}' />
                    </div>
                    <div class="row" style="margin-top: 35px;">
                        <div class="col-6">
                            <span t-field="o.invoice_payment_term_id.name"/>
                        </div>
                        <div class="col-">
                            <span t-field="o.invoice_date_due"/>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row" style="margin-top: 10px;">
                <div class="col-1"></div>
                <div class="col-4" style="margin-left: 10px;">
                    <span style="text-align: left;" t-field="o.payment_reference" />
                </div>
                <div class="col-1"></div>
                <div class="col-4" style="margin-left: 10px;">
                    <span t-field="o.invoice_user_id" />
                </div>
            </div>
        </div>
    </template>
</odoo>