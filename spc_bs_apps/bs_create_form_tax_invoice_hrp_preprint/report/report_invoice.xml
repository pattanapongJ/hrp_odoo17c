<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="request_layout">
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>

        <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
            <t t-call="bs_create_form_tax_invoice_hrp_preprint.report_header_info" />
        </div>

        <div t-attf-class="article o_report_layout_standard o_company_#{company.id}_layout" 
             t-att-data-oe-model="o and o._name" 
             t-att-data-oe-id="o and o.id" 
             t-att-data-oe-lang="o and o.env.context.get('lang')">
            
            <t t-out="0" /> 
        </div>

        <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout">
            <t t-call="bs_create_form_tax_invoice_hrp_preprint.report_footer" />
        </div>
    </template>

    <template id="bs_form_preprint_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="bs_create_form_tax_invoice_hrp_preprint.request_layout">
                    <t t-call="bs_create_form_tax_invoice_hrp_preprint.report_main_content" />
                </t>
            </t>
        </t>
    </template>
</odoo>