<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_footer_gee_plus">
        <div style="font-family: 'THSarabunNew'; font-size: 18px;">
            <div class="row">
                <div class="col-7">
                </div>
                <div class="col-3"/>
                <div class="col-2 text-end" style="padding-top: 130px;">
                    <div class="row">
                        <div class="col-12">
                            <span t-esc="('{:,.2f}').format(o.amount_untaxed)"/>
                        </div>
                    </div>
                    <div class="row" style="margin-top: 20px;">
                        <div class="col-12">
                            <span t-esc="('{:,.2f}').format(o.amount_tax)"/>
                        </div>
                    </div>
                    <div class="row" style="margin-top: 20px;">
                        <div class="col-12">
                            <span t-esc="('{:,.2f}').format(o.amount_total)"/>
                        </div>
                    </div>
                </div>
            </div>
        </template>
    </odoo>