<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_header_info_gee_plus">
        <div style="font-family: 'THSarabunNew'; font-size: 18px;">
            <div class="row">
                <div class="col-11">
                </div>
                <div class="col-1">
                    <div class="row">
                        <span style="text-align: left;" t-field="o.name" />
                    </div>
                    <div class="row" style="margin-top: 15px">
                        <span style="text-align: left;" t-field="o.date" t-options='{"widget":"date"}'/>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <span style="margin-left: 10px;" t-field="o.partner_id.ref" />
                </div>
            </div>
            <div class="row" style="margin-top: 20px; margin-left: 20px;">
                <div class="col-6">
                    <div class="row" style="margin-left: 12px;">
                        <div style="line-height: 1.5;">
                            <span t-field="o.partner_id.name" />
                        </div>
                    </div>
                    <div class="row" style="margin-top: 15px; margin-left: 12px;">
                        <div style="line-height: 1.5;">
                            <span t-field="o.partner_id.street" />
                            <span t-field="o.partner_id.street2" />
                            <span t-field="o.partner_id.city" />
                            <span t-field="o.partner_id.state_id" />
                            <span t-field="o.partner_id.zip" />
                            <span t-field="o.partner_id.country_id" />
                        </div>
                    </div>
                </div>
                <div class="col-3">
                    <div class="row" style="margin-top: 30px; padding-left: 20px; ">
                        <span t-field="o.payment_reference" />
                    </div>
                    <div class="row" style="margin-top: 30px; padding-left: 20px; ">
                        <span style="white-space: nowrap;" t-field="o.invoice_payment_term_id.name" />
                    </div>
                </div>
                <div class="col-3">

                    <div class="row" style="margin-top: 30px; margin-left: 20px;">
                        <span t-field="o.invoice_date_due" t-options='{"widget":"date"}' />
                    </div>
                    <div class="row" style="margin-top: 25px;">
                        <span t-field="o.invoice_user_id.name" />
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>