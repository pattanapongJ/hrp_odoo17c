<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_main_content_gee_plus">
        <div style="font-family: 'THSarabunNew'; font-size: 18px;" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id">
            <table class="table table-borderless">
                <thead>
                    <tr>
                        <th style="width: 5%;"/>
                        <th style="width: 45%;"/>
                        <th style="width: 12.5%;"/>
                        <th style="width: 12.5%;"/>
                        <th style="width: 12.5%;"/>
                        <th style="width: 12.5%;"/>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="line_number" t-value="0"/>
                    <tr t-foreach="o.invoice_line_ids" t-as="line">
                        <td style="text-align: left;">
                            <t t-set="line_number" t-value="line_number + 1"/>
                            <span t-esc="line_number"/>
                        </td>
                        <td style="text-align: left;">
                            <span t-field="line.product_id.name"/>
                            <span t-field="line.name"/>
                        </td>
                        <td style="text-align: right; padding-left:40px;">
                            <span t-esc="('{:,.2f}').format(line.quantity)"/>
                        </td>
                        <td style="text-align: right; padding-right:30px;">
                            <span t-field="line.product_uom_id"/>
                        </td>
                        <td style="text-align: right; padding-right:40px;">
                            <span t-field="line.multi_discount"/>
                        </td>
                        <td style="text-align: right; padding-left:40px;">
                            <span t-esc="('{:,.2f}').format(line.price_subtotal)"/>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </template>
</odoo>