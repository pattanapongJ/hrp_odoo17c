<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- custom report template -->
    <template id="request_layout">
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <!-- Multicompany -->
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>

        <!-- header -->
        <div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
            <div class="row mx-0 pt-1 pb-1" style="font-family: 'Kanit-Light';">
                <t t-call="bs_create_report_billing_hrp_a5.report_compay_info"/>
                <div class="col-4 text-right">
                    <span style="font-size: 18px">ใบวางบิล</span>
                    <div t-if="report_type == 'pdf'" class="text-muted" style="font-size:11px;">
                        <span>หน้าที่ </span>
                        <span class="page" />
                        <span> / </span>
                        <span class="topage" />
                    </div>
                </div>
            </div>
            <t t-call="bs_create_report_billing_hrp_a5.report_partner_info"/>
        </div>

        <!-- content or article -->
        <div t-attf-class="article o_report_layout_standard o_company_#{company.id}_layout" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-raw="0" />
        </div>

        <!-- footer -->
        <div t-attf-class="footer o_standard_footer o_company_#{company.id}_layout">
            <t t-call="bs_create_report_billing_hrp_a5.report_footer" />
        </div>
    </template>
</odoo>
