<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_partner_info">
        <div class="row mx-0 pt-1 pb-1" style="font-family: 'Kanit-Light'; font-size: 13.64px">
                <div class="col-1"></div>
                <div class="col-6">
                    <div class="row">
                        <div class="col-2 mb-0 p-0 text-left font-weight-bold">
                            <span>ลูกค้า: </span>
                        </div>
                        <div class="col-10 p-0 mb-0 text-left">
                            <span>
                                <t t-if="o.partner_id.partner_code">
                                    <span t-field="o.partner_id.partner_code" />
                                </t>
                                <t t-if="not o.partner_id.partner_code">
                                    <span> - </span>
                                </t>
                            </span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 p-0 mb-0 text-left">
                            <span t-field="o.partner_id" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12 p-0 mb-0 text-left">
                            <span t-field="o.partner_id.street" />
                            <span t-field="o.partner_id.street2" />
                            <span t-field="o.partner_id.city" />
                            <br/>
                            <span t-field="o.partner_id.state_id" />
                            <span t-field="o.partner_id.zip" />
                            <span t-field="o.partner_id.country_id" />
                        </div>
                    </div>
                </div>
                <div class="col-1"></div>
                <div class="col-4 pt-1 pb-1 mr-1 ml-5">
                    <div class="row pt-1 pb-1">
                        <div class="col-6 p-0 mb-0 pl-2 text-left">
                            <span>เลขที่ใบวางบิล:  </span>
                        </div>
                        <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                            <span t-field="o.name" />
                        </div>
                    </div>
                    <div class="row pt-1 pb-1">
                        <div class="col-6 p-0 mb-0 pl-2 text-left">
                            <span>วันที่: </span>
                        </div>
                        <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                            <span t-field="o.date" />
                        </div>
                    </div>
                    <div class="row pt-1 pb-1">
                        <div class="col-6 p-0 mb-0 pl-2 text-left">
                            <span>เงื่อนไขการชำระเงิน: </span>
                        </div>
                        <div class="col-6 p-0 mb-0 text-left" style="margin-left:-20px">
                            <span>
                                <t t-if="o.partner_id.property_payment_term_id">
                                    <span t-field="o.partner_id.property_payment_term_id.name" />
                                </t>
                                <t t-if="not o.partner_id.property_payment_term_id">
                                    -
                                </t>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
    </template>
</odoo>
