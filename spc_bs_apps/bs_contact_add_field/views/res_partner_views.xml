<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_partner_view_form_partner_code" model="ir.ui.view">
        <field name="name">res.partner.partner.code.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_group_id']" position="after">
                <field name="partner_code"/>
            </xpath>
        </field>
    </record>

</odoo>
