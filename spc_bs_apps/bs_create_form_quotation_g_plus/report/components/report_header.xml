<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <template id="report_header_info_g_plus">
        <div class="row">
            <div class="col-12" style="font-family: 'AngsanaUPC'; border-right: 1px solid #000; border-left: 1px solid #000; border-top: 1px solid #000;">
                <div class="row" style="border-bottom: 1px solid #000;">
                    <div class="col-2">
                        <div class="row">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="max-height: 55pt; max-width: 55pt;"/>
                        </div>
                    </div>
                    <div class="col-10 text-left" style="font-weight: bold; font-size: 14.08px;">
                        <div class="row">
                            <div class = "col-12" style="white-space: nowrap; overflow: hidden;">
                                <span style="font-size: 17.6px; font-weight: bold;" t-field="o.company_id.name"/>
                            </div>
                        </div> 
                        <div class="row">
                            <div class="col-3">
                                <span>Tel : </span>
                                <t t-if="o.company_id.phone">
                                    <span t-esc="o.company_id.phone"/>
                                </t>
                                <t t-if="not o.company_id.phone">
                                    <span> - </span>
                                </t>
                            </div>
                            <div class="col-3">
                                <span>Fax : </span>
                                <t t-if="o.company_id.fax">
                                    <span t-esc="o.company_id.fax"/>
                                </t>
                                <t t-if="not o.company_id.fax">
                                    <span> - </span>
                                </t>
                            </div>
                            <div class="col-6"></div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <span>E-Mail :   </span>
                                <t t-if="o.company_id.email">
                                    <span t-esc="o.company_id.email"/>
                                </t>
                                <t t-if="not o.company_id.email">
                                    <span> - </span>
                                </t>
                            </div>

                        </div>
                        <div class="row">
                            <div class="col-12">
                                <span>Website : </span>
                                <t t-if="o.company_id.website">
                                    <span t-esc="o.company_id.website"/>
                                </t>
                                <t t-if="not o.company_id.website">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row pt-2" style="font-weight: Regular; font-size: 12.90px;">
                    <div class="col-11"/>
                    <div class="col-1 text-center">
                        <span>Page</span>
                        <span class="page"/>
                        <span>/</span>
                        <span class="topage"/>
                    </div>
                </div>
                <div class="row pb-2 pt-3" style="font-weight: bold; font-size: 16.42px;">
                    <div class="col-4"/>
                    <div class="col-4 text-center">
                        <span>Quotation</span>
                    </div>
                    <div class="col-4 "/>
                </div>
                <div class="row py-1" style="font-size: 12.90px; border-bottom: 1px solid #000; padding-left:3px;">
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Attention</span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.partner_id.contact_person">
                                    <span t-field="o.partner_id.contact_person"/>
                                </t>
                                <t t-if="not o.partner_id.contact_person">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 ">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Quotation No</span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.name">
                                    <span t-field="o.name"/>
                                </t>
                                <t t-if="not o.name">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row py-1" style="font-size: 12.90px; border-bottom: 1px solid #000; padding-left:3px;">
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Company  </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.partner_id.name_company">
                                    <span t-field="o.partner_id.name_company"/>
                                </t>
                                <t t-if="not o.partner_id.name_company">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Date </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.date_order">
                                    <span t-esc="o.date_order"/>
                                </t>
                                <t t-if="not o.date_order">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row py-1" style="font-size: 12.90px; border-bottom: 1px solid #000; padding-left:3px;">
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Tel </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.partner_id.phone">
                                    <span t-esc="o.partner_id.phone"/>
                                </t>
                                <t t-if="not o.partner_id.phone">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Delivery Time </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.delivery_time">
                                    <span t-esc="o.delivery_time"/>
                                </t>
                                <t t-if="not o.delivery_time">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row py-1" style="font-size: 12.90px; border-bottom: 1px solid #000; padding-left:3px;">
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Mail </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8  text-left">
                                <t t-if="o.partner_id.email">
                                    <span t-esc="o.partner_id.email"/>
                                </t>
                                <t t-if="not o.partner_id.email">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Term of Payment </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.payment_term_id">
                                    <span t-esc="o.payment_term_id"/>
                                </t>
                                <t t-if="not o.payment_term_id">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row py-1" style="font-size: 12.90px; padding-left:3px;">
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>From </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.user_id">
                                    <span t-esc="o.user_id.name"/>
                                    <span> ( </span>
                                    <span t-esc="o.user_id.phone or '-'"/>
                                    <span> )</span>
                                </t>
                                <t t-if="not o.user_id">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="row">
                            <div class="col-3 text-left" style="font-weight: bold;">
                                <span>Validity : </span>
                            </div>
                            <div class = "col-1 text-center">
                                <spam>:</spam>
                            </div>
                            <div class="col-8 text-left">
                                <t t-if="o.validity_date">
                                    <span t-esc="o.validity_date"/>
                                </t>
                                <t t-if="not o.validity_date">
                                    <span> - </span>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </template>
</odoo>
